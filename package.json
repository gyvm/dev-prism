{
  "name": "pr-weekly-report",
  "version": "0.1.0",
  "description": "Weekly GitHub PR insights — DORA, timelines, review correlation, AI summaries.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.15.0"
  },
  "bin": {
    "pr-weekly-report": "dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "commands",
    "agents",
    ".claude-plugin",
    "action.yml",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/cli/report.ts --bundle --platform=node --target=node24 --format=esm --outfile=dist/cli.js --banner:js='#!/usr/bin/env node' --packages=external",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "report": "tsx src/cli/report.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.3.0",
    "markdown-it": "^14.1.1",
    "smol-toml": "^1.6.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.6.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
