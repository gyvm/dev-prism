---
import Layout from "../layouts/Layout.astro";
import Explore from "../islands/Explore";
import { PAGE_STYLES } from "../../renderers/page-styles.js";

// Explore is a client-only React island: it boots DuckDB-WASM in the browser,
// queries the parquet DWH live, and renders with the same renderers as the
// frozen reports (parity). PAGE_STYLES is the report stylesheet so the rendered
// metric cards / gantt / bipartite output looks identical to Reports.
---

<Layout title="Explore — PR Analytics" active="explore">
  <style is:global set:html={PAGE_STYLES}></style>
  {/* is:global is REQUIRED: <Explore client:only="react"> renders the whole
      island in the browser, so Astro-scoped selectors (cid-attributed) never
      match its DOM. Without this, these .explore-* rules are dead code and the
      controls fall back to UA defaults — which Tailwind preflight then strips.
      Phase 3 replaces these controls with React Aria + daisyUI. */}
  <style is:global>
    .explore-filters { display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-end; margin: 14px 0; }
    .explore-field { display: grid; gap: 3px; font-size: 12px; color: #586574; }
    .explore-field input, .explore-field select { font-size: 13px; padding: 5px 7px; border: 1px solid #d6dee8; border-radius: 6px; }
    .explore-field input[type="checkbox"] { justify-self: start; width: 16px; height: 16px; }
    .explore-filters button[type="submit"] { align-self: flex-end; padding: 7px 16px; border: 0; border-radius: 6px; background: #2563eb; color: #fff; font-size: 13px; font-weight: 650; cursor: pointer; }
    .explore-filters button[type="submit"]:hover { background: #1d4fd7; }
    .explore-status { color: #586574; font-size: 13px; margin: 4px 0 0; }
    /* Period picker (presets + React Aria DateRangePicker) spans its own row. */
    .explore-period { flex-basis: 100%; display: flex; flex-wrap: wrap; gap: 8px 14px; align-items: center; }
    .explore-presets { display: flex; flex-wrap: wrap; gap: 6px; }
    .explore-preset { padding: 6px 12px; border: 1px solid #d6dee8; border-radius: 8px; background: #fff; font-size: 12px; font-weight: 600; color: #202733; cursor: pointer; transition: border-color .12s ease, background .12s ease; }
    .explore-preset:hover { border-color: #0891b2; background: #f0fbfd; }
    .explore-preset:focus-visible { outline: 2px solid #2563eb; outline-offset: 1px; }

    /* React Aria DateRangePicker — DESIGN.md tokens (cyan accent, no purple). */
    .rac-group { display: inline-flex; align-items: center; gap: 4px; padding: 5px 6px 5px 10px; border: 1px solid #d6dee8; border-radius: 8px; background: #fff; transition: border-color .12s ease, box-shadow .12s ease; }
    .rac-group[data-focus-within] { border-color: #0891b2; box-shadow: 0 0 0 3px rgba(8,145,178,.12); }
    .rac-dateinput { display: inline-flex; padding: 1px 2px; font-size: 13px; font-variant-numeric: tabular-nums; color: #202733; white-space: nowrap; }
    .rac-segment { padding: 1px 2px; border-radius: 4px; outline: none; color: #202733; text-align: end; }
    .rac-segment[data-placeholder] { color: #a4adb8; font-style: normal; }
    .rac-segment[data-focused] { background: #0891b2; color: #fff; }
    .rac-dash { color: #728091; font-size: 12px; padding: 0 2px; }
    .rac-calbtn { display: inline-grid; place-items: center; width: 26px; height: 26px; margin-left: 2px; border: 0; border-radius: 6px; background: #eef3f8; font-size: 13px; line-height: 1; cursor: pointer; }
    .rac-calbtn[data-hovered] { background: #dceef2; }
    .rac-calbtn[data-focus-visible] { outline: 2px solid #2563eb; outline-offset: 1px; }
    .rac-popover { background: #fff; border: 1px solid #d6dee8; border-radius: 12px; box-shadow: 0 12px 32px rgba(16,24,40,.16); }
    .rac-dialog { padding: 12px 14px; outline: none; }
    .rac-calheader { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
    .rac-calheading { margin: 0; font-size: 13px; font-weight: 700; color: #202733; text-align: center; flex: 1; }
    .rac-navbtn { width: 28px; height: 28px; border: 1px solid #e2e8f0; border-radius: 7px; background: #fff; color: #202733; font-size: 15px; line-height: 1; cursor: pointer; }
    .rac-navbtn[data-hovered] { border-color: #0891b2; background: #f0fbfd; }
    .rac-navbtn[data-focus-visible] { outline: 2px solid #2563eb; outline-offset: 1px; }
    .rac-calgrids { display: flex; gap: 18px; }
    .rac-calgrid { border-collapse: collapse; }
    .rac-calgrid th { padding: 4px; font-size: 11px; font-weight: 600; color: #728091; }
    .rac-calcell { width: 32px; height: 30px; text-align: center; font-size: 12px; color: #202733; border-radius: 7px; cursor: pointer; outline: none; }
    .rac-calcell[data-outside-month] { display: none; }
    .rac-calcell[data-hovered] { background: #eef3f8; }
    .rac-calcell[data-selected] { background: #e0f4f8; border-radius: 0; }
    .rac-calcell[data-selection-start] { border-top-left-radius: 7px; border-bottom-left-radius: 7px; }
    .rac-calcell[data-selection-end] { border-top-right-radius: 7px; border-bottom-right-radius: 7px; }
    .rac-calcell[data-selection-start], .rac-calcell[data-selection-end] { background: #0891b2; color: #fff; font-weight: 700; }
    .rac-calcell[data-focus-visible] { outline: 2px solid #2563eb; outline-offset: -2px; }
    .rac-calcell[data-disabled] { color: #c2c9d2; cursor: default; }
    /* Searchable repo/user multiselect. */
    .explore-ms { position: relative; }
    .explore-ms__btn { min-width: 130px; text-align: left; padding: 5px 9px; border: 1px solid #d6dee8; border-radius: 6px; background: #fff; font-size: 13px; color: #202733; cursor: pointer; }
    .explore-ms__btn:hover:not(:disabled) { border-color: #0891b2; }
    .explore-ms__btn:disabled { color: #a4adb8; cursor: default; }
    .explore-ms__panel { position: absolute; z-index: 20; top: calc(100% + 4px); left: 0; width: 240px; max-height: 280px; overflow: auto; padding: 8px; background: #fff; border: 1px solid #d6dee8; border-radius: 8px; box-shadow: 0 6px 18px rgba(16,24,40,.12); }
    .explore-ms__search { width: 100%; box-sizing: border-box; margin-bottom: 6px; padding: 5px 7px; border: 1px solid #d6dee8; border-radius: 6px; font-size: 13px; }
    .explore-ms__clear { display: block; width: 100%; text-align: left; padding: 4px 6px; border: 0; background: none; color: #0891b2; font-size: 12px; cursor: pointer; }
    .explore-ms__list { list-style: none; margin: 0; padding: 0; }
    .explore-ms__opt { display: flex; align-items: center; gap: 7px; padding: 5px 6px; border-radius: 6px; font-size: 13px; cursor: pointer; }
    .explore-ms__opt:hover { background: #eef3f8; }
    .explore-ms__opt input { width: 15px; height: 15px; }
    .explore-ms__empty { padding: 8px 6px; color: #728091; font-size: 13px; }
    /* Clear the fixed sidebar toggle (top-left) so the heading is not covered. */
    .explore-main { max-width: 1100px; margin: 0 auto; padding: 56px 20px 48px; }
  </style>
  <Explore client:only="react" />
</Layout>
