---
import Layout from "../layouts/Layout.astro";
import Explore from "../islands/Explore";
import { PAGE_STYLES } from "../../renderers/page-styles.js";

// Explore is a client-only React island: it boots DuckDB-WASM in the browser,
// queries the parquet DWH live, and renders with the same renderers as the
// frozen reports (parity). PAGE_STYLES is the report stylesheet so the rendered
// metric cards / gantt / bipartite output looks identical to Reports.
---

<Layout title="Explore — PR Analytics" active="explore">
  <style is:global set:html={PAGE_STYLES}></style>
  <style>
    .explore-filters { display: flex; flex-wrap: wrap; gap: 12px; align-items: flex-end; margin: 14px 0; }
    .explore-field { display: grid; gap: 3px; font-size: 12px; color: #586574; }
    .explore-field input, .explore-field select { font-size: 13px; padding: 5px 7px; border: 1px solid #d6dee8; border-radius: 6px; }
    .explore-field input[type="checkbox"] { justify-self: start; width: 16px; height: 16px; }
    .explore-filters button[type="submit"] { align-self: flex-end; padding: 7px 16px; border: 0; border-radius: 6px; background: #2563eb; color: #fff; font-size: 13px; font-weight: 650; cursor: pointer; }
    .explore-filters button[type="submit"]:hover { background: #1d4fd7; }
    .explore-status { color: #586574; font-size: 13px; margin: 4px 0 0; }
    /* Period picker (presets + react-day-picker range) spans its own row. */
    .explore-period { flex-basis: 100%; display: grid; gap: 8px; }
    .explore-presets { display: flex; flex-wrap: wrap; gap: 6px; }
    .explore-preset { padding: 5px 11px; border: 1px solid #d6dee8; border-radius: 6px; background: #fff; font-size: 12px; color: #202733; cursor: pointer; }
    .explore-preset:hover { border-color: #0891b2; }
    .explore-preset:focus-visible { outline: 2px solid #2563eb; outline-offset: 1px; }
    .explore-preset--cal { font-variant-numeric: tabular-nums; color: #586574; }
    .explore-calendar { width: max-content; padding: 8px 12px; background: #fff; border: 1px solid #d6dee8; border-radius: 8px;
      --rdp-accent-color: #0891b2; --rdp-accent-background-color: #eef3f8; --rdp-today-color: #0891b2; }
    /* Searchable repo/user multiselect. */
    .explore-ms { position: relative; }
    .explore-ms__btn { min-width: 130px; text-align: left; padding: 5px 9px; border: 1px solid #d6dee8; border-radius: 6px; background: #fff; font-size: 13px; color: #202733; cursor: pointer; }
    .explore-ms__btn:hover:not(:disabled) { border-color: #0891b2; }
    .explore-ms__btn:disabled { color: #a4adb8; cursor: default; }
    .explore-ms__panel { position: absolute; z-index: 20; top: calc(100% + 4px); left: 0; width: 240px; max-height: 280px; overflow: auto; padding: 8px; background: #fff; border: 1px solid #d6dee8; border-radius: 8px; box-shadow: 0 6px 18px rgba(16,24,40,.12); }
    .explore-ms__search { width: 100%; box-sizing: border-box; margin-bottom: 6px; padding: 5px 7px; border: 1px solid #d6dee8; border-radius: 6px; font-size: 13px; }
    .explore-ms__clear { display: block; width: 100%; text-align: left; padding: 4px 6px; border: 0; background: none; color: #0891b2; font-size: 12px; cursor: pointer; }
    .explore-ms__list { list-style: none; margin: 0; padding: 0; }
    .explore-ms__opt { display: flex; align-items: center; gap: 7px; padding: 5px 6px; border-radius: 6px; font-size: 13px; cursor: pointer; }
    .explore-ms__opt:hover { background: #eef3f8; }
    .explore-ms__opt input { width: 15px; height: 15px; }
    .explore-ms__empty { padding: 8px 6px; color: #728091; font-size: 13px; }
    /* Clear the fixed sidebar toggle (top-left) so the heading is not covered. */
    .explore-main { max-width: 1100px; margin: 0 auto; padding: 56px 20px 48px; }
  </style>
  <Explore client:only="react" />
</Layout>
