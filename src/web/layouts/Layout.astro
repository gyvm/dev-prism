---
import "../../ui/theme.css";
import { sidebarHtml, SIDEBAR_STYLES, type SidebarActive } from "../shell/sidebar.ts";

interface Props {
  title?: string;
  active?: SidebarActive;
}

const { title = "PR Analytics", active = null } = Astro.props;
// BASE_URL mirrors the configured base and is NOT guaranteed to end in "/"
// (e.g. "/dev-prism" with no trailing slash). Normalize so Reports and
// Explore are clean child paths of the base (the base root itself redirects to
// Explore — see pages/index.astro).
// Trailing slashes are required: a bare `/explore` collides with the sibling
// module src/web/explore.ts in dev (Vite serves it as JS); `/explore/` resolves
// to the page. Slashes are also the canonical directory-format URLs in prod.
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : `${raw}/`;
const links = { reportsHref: `${base}reports/`, exploreHref: `${base}explore/`, active };
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global set:html={SIDEBAR_STYLES}></style>
  </head>
  <body>
    <Fragment set:html={sidebarHtml(links)} />
    <slot />
    <script>
      import { mountSidebar } from "../shell/sidebar.ts";
      mountSidebar();
    </script>
  </body>
</html>
