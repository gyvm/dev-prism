[general]
timezone = "Asia/Tokyo"

# 各エントリは "owner/name" もしくは "owner/*"。
# "owner/*" は archived を除く owner 配下の全リポジトリに展開される
# (トークンに権限があれば private も含む)。
[repositories]
include = [
  "your-org/*",
]

# [limits] は省略可。1 PR あたりの取得上限を制御する。
# 省略時は src/shared/config.ts の DEFAULT_LIMITS が適用される。
[limits]
maxPrs                = 50
maxCommentsPerPr      = 80
maxReviewThreadsPerPr = 60
maxFilesPerPr         = 120
maxCommitsPerPr       = 80
maxBodyLength         = 4000

# [bots] は省略可。bot と見なす GitHub login の正規表現 (大文字小文字区別なし)。
[bots]
patterns = [
  "^renovate$",
  "^dependabot$",
  "\\[bot\\]$",
]

# [ai] は省略可。Copilot SDK が使うモデルを指定する。
# 省略時は Copilot SDK のデフォルト (Claude Sonnet 4.5 など)。
# 利用可能なモデル ID は `copilot` CLI 内で `/model` を実行するか、
# Copilot SDK の `client.listModels()` で確認できる。
[ai]
model = "gpt-5.3-codex"
